      <joint name="bucket_spin" type="hinge" axis="0 0 1"/>
      <!-- Heavy bottom disc -->
      <geom name="bottom" type="cylinder"
            pos="0 0 0.0060" size="0.1 0.0060"
            material="bucket" mass="12.0"/>
