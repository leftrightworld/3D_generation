<mujoco model="beam_buckling">
  <!-- Euler beam buckling: a slender column discretized into 10 segments
       joined by torsional hinge springs (stiffness=26.0, damping=0.3).
       A heavy block (0.55 kg) sits on top.  Applied load (7.85 N)
       exceeds the Euler critical load (6.42 N) by 1.22×, so
       the small initial perturbation grows into a smooth buckled curve. -->
  <compiler angle="radian" coordinate="local" autolimits="true"/>
  <option timestep="0.001" gravity="0 0 -9.81" integrator="implicitfast"/>

  <visual>
    <headlight diffuse="0 0 0" ambient="0.50 0.48 0.55" specular="0 0 0"/>
    <rgba haze="0.94 0.91 0.90 1"/>
    <global azimuth="120" elevation="-15" offwidth="1920" offheight="1080" fovy="38"/>
    <quality shadowsize="8192" offsamples="8"/>
    <map shadowclip="6" shadowscale="0.7"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="flat"
             rgb1="0.74 0.68 0.86" rgb2="0.74 0.68 0.86"
             width="512" height="512" mark="none" markrgb="0 0 0"/>
    <material name="floor_mat" rgba="0.94 0.91 0.90 1" specular="0" shininess="0"/>
    <material name="wood"      rgba="0.93 0.82 0.58 1" specular="0.1" shininess="0.1"/>
    <material name="wood_dark" rgba="0.78 0.65 0.40 1" specular="0.1" shininess="0.1"/>
    <material name="column"    rgba="0.86 0.78 0.55 1" specular="0.30" shininess="0.4"/>
    <material name="payload"   rgba="0.86 0.34 0.30 1" specular="0.35" shininess="0.4"/>
  </asset>

  <worldbody>
    <light pos="0 0 12" dir="-0.30 0.55 -1" directional="true" castshadow="true"
           diffuse="0.85 0.82 0.78" specular="0.15 0.15 0.15"/>
    <light pos="0 0 8" dir="0.40 -0.30 -1" directional="true" castshadow="false"
           diffuse="0.28 0.28 0.34" specular="0 0 0"/>

    <geom name="floor" type="plane" size="40 40 0.1" material="floor_mat"/>

    <!-- Fixed base block (the column is pinned to its top face). -->
    <geom type="box" pos="0 0 0.0400"
          size="0.1000 0.1000 0.0400"
          material="wood_dark"/>

    <!-- Column: nested chain of 10 segments connected by torsional hinges.
         All hinges rotate about the y-axis, so buckling deflection is in
         the x-direction (visible directly in a side-view camera). -->
    <body name="seg0_body" pos="0 0 0.0800">
      <joint name="h0" type="hinge" axis="0 1 0" stiffness="26.0" damping="0.3"/>
      <geom name="seg0" type="box" pos="0 0 0.0500" size="0.0060 0.0060 0.0500" material="column" mass="0.025"/>
      <body name="seg1_body" pos="0 0 0.1000">
        <joint name="h1" type="hinge" axis="0 1 0" stiffness="26.0" damping="0.3"/>
        <geom name="seg1" type="box" pos="0 0 0.0500" size="0.0060 0.0060 0.0500" material="column" mass="0.025"/>
        <body name="seg2_body" pos="0 0 0.1000">
          <joint name="h2" type="hinge" axis="0 1 0" stiffness="26.0" damping="0.3"/>
          <geom name="seg2" type="box" pos="0 0 0.0500" size="0.0060 0.0060 0.0500" material="column" mass="0.025"/>
          <body name="seg3_body" pos="0 0 0.1000">
            <joint name="h3" type="hinge" axis="0 1 0" stiffness="26.0" damping="0.3"/>
            <geom name="seg3" type="box" pos="0 0 0.0500" size="0.0060 0.0060 0.0500" material="column" mass="0.025"/>
            <body name="seg4_body" pos="0 0 0.1000">
              <joint name="h4" type="hinge" axis="0 1 0" stiffness="26.0" damping="0.3"/>
              <geom name="seg4" type="box" pos="0 0 0.0500" size="0.0060 0.0060 0.0500" material="column" mass="0.025"/>
              <body name="seg5_body" pos="0 0 0.1000">
                <joint name="h5" type="hinge" axis="0 1 0" stiffness="26.0" damping="0.3"/>
                <geom name="seg5" type="box" pos="0 0 0.0500" size="0.0060 0.0060 0.0500" material="column" mass="0.025"/>
                <body name="seg6_body" pos="0 0 0.1000">
                  <joint name="h6" type="hinge" axis="0 1 0" stiffness="26.0" damping="0.3"/>
                  <geom name="seg6" type="box" pos="0 0 0.0500" size="0.0060 0.0060 0.0500" material="column" mass="0.025"/>
                  <body name="seg7_body" pos="0 0 0.1000">
                    <joint name="h7" type="hinge" axis="0 1 0" stiffness="26.0" damping="0.3"/>
                    <geom name="seg7" type="box" pos="0 0 0.0500" size="0.0060 0.0060 0.0500" material="column" mass="0.025"/>
                    <body name="seg8_body" pos="0 0 0.1000">
                      <joint name="h8" type="hinge" axis="0 1 0" stiffness="26.0" damping="0.3"/>
                      <geom name="seg8" type="box" pos="0 0 0.0500" size="0.0060 0.0060 0.0500" material="column" mass="0.025"/>
                      <body name="seg9_body" pos="0 0 0.1000">
                        <joint name="h9" type="hinge" axis="0 1 0" stiffness="26.0" damping="0.3"/>
                        <geom name="seg9" type="box" pos="0 0 0.0500" size="0.0060 0.0060 0.0500" material="column" mass="0.025"/>
                        <geom name="top_mass" type="box" pos="0 0 0.1375" size="0.0375 0.0375 0.0375" material="payload" mass="0.55"/>
                      </body>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>

    <!-- Side view from -y with slight 3/4 tilt, pulled back so the FULL
         column (z 0 to ~1.15) and the bow direction (+x up to ~0.7 m) all
         stay inside the frame at fovy=40. -->
    <camera name="cam" pos="0.70 -2.80 0.75" fovy="40"
            xyaxes="0.985 0.158 0   -0.011 0.069 0.998"/>
  </worldbody>
</mujoco>
