<mujoco model="bowling_scene">
  <compiler angle="radian" coordinate="local" autolimits="true"/>
  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast"
          impratio="3" cone="elliptic"/>

  <visual>
    <headlight diffuse="0 0 0" ambient="0.50 0.48 0.55" specular="0 0 0"/>
    <rgba haze="0.94 0.91 0.90 1"/>
    <global azimuth="120" elevation="-15" offwidth="1920" offheight="1080" fovy="35"/>
    <quality shadowsize="8192" offsamples="8"/>
    <map shadowclip="6" shadowscale="0.7"/>
  </visual>

  <asset>
    <!-- Flat purple sky, clean horizon (same recipe as the pendulum) -->
    <texture type="skybox" builtin="flat"
             rgb1="0.74 0.68 0.86" rgb2="0.74 0.68 0.86"
             width="512" height="512"
             mark="none" markrgb="0 0 0"/>

    <material name="floor_mat" rgba="0.94 0.91 0.90 1"
              reflectance="0.0" specular="0.0" shininess="0.0"/>
    <material name="lane_wood" rgba="0.93 0.82 0.58 1"
              specular="0.1" shininess="0.1"/>
    <material name="rail_wood" rgba="0.85 0.72 0.48 1"
              specular="0.1" shininess="0.1"/>
    <material name="pin_white" rgba="0.96 0.94 0.92 1"
              specular="0.25" shininess="0.3"/>
    <material name="pin_red" rgba="0.88 0.32 0.30 1"
              specular="0.15" shininess="0.2"/>
    <material name="ball_blue" rgba="0.28 0.22 0.55 1"
              specular="0.45" shininess="0.6"/>
  </asset>

  <default>
    <!-- Generous friction so pins resist tipping until hit, and ball rolls -->
    <geom friction="0.8 0.05 0.001" solref="0.005 1" solimp="0.95 0.99 0.001"/>
  </default>

  <worldbody>
    <!-- Lights -->
    <light pos="0 0 12" dir="-0.30 0.55 -1" directional="true" castshadow="true"
           diffuse="0.85 0.82 0.78" specular="0.15 0.15 0.15"/>
    <light pos="0 0 8" dir="0.40 -0.30 -1" directional="true" castshadow="false"
           diffuse="0.28 0.28 0.34" specular="0 0 0"/>

    <!-- Floor -->
    <geom name="floor" type="plane" size="40 40 0.1" material="floor_mat"/>

    <!-- Bowling lane: thin wooden plank elevated above the floor -->
    <geom name="lane" type="box" size="3.5 0.42 0.025"
          pos="0 0 0.05" material="lane_wood"/>
    <!-- Lane side rails (gutters) -->
    <geom name="rail_left"  type="box" size="3.5 0.04 0.06"
          pos="0 -0.46 0.08" material="rail_wood"/>
    <geom name="rail_right" type="box" size="3.5 0.04 0.06"
          pos="0  0.46 0.08" material="rail_wood"/>

    <!-- Bowling ball, free body, starts at far end of lane -->
    <body name="ball" pos="-2.8 0 0.20">
      <joint name="ball_free" type="free"/>
      <geom name="ball_geom" type="sphere" size="0.13" mass="6"
            material="ball_blue"/>
    </body>

    <!-- 10 pins in standard triangle formation.
         Each pin = thin capsule, center z = lane_top + half_capsule_length -->
    <!-- lane top z = 0.075, capsule radius 0.035 + half-len 0.10 → center z = 0.075 + 0.10 + 0.035 = 0.21 -->
    <!-- Row 1: head pin -->
    <body name="pin1" pos="2.2 0 0.21">
      <joint type="free"/>
      <geom type="capsule" size="0.035 0.10" material="pin_white" mass="0.45"/>
      <geom type="capsule" size="0.0355 0.012" pos="0 0 0.075" material="pin_red" mass="0.001"/>
    </body>
    <!-- Row 2 -->
    <body name="pin2" pos="2.4 -0.11 0.21">
      <joint type="free"/>
      <geom type="capsule" size="0.035 0.10" material="pin_white" mass="0.45"/>
      <geom type="capsule" size="0.0355 0.012" pos="0 0 0.075" material="pin_red" mass="0.001"/>
    </body>
    <body name="pin3" pos="2.4 0.11 0.21">
      <joint type="free"/>
      <geom type="capsule" size="0.035 0.10" material="pin_white" mass="0.45"/>
      <geom type="capsule" size="0.0355 0.012" pos="0 0 0.075" material="pin_red" mass="0.001"/>
    </body>
    <!-- Row 3 -->
    <body name="pin4" pos="2.6 -0.22 0.21">
      <joint type="free"/>
      <geom type="capsule" size="0.035 0.10" material="pin_white" mass="0.45"/>
      <geom type="capsule" size="0.0355 0.012" pos="0 0 0.075" material="pin_red" mass="0.001"/>
    </body>
    <body name="pin5" pos="2.6 0 0.21">
      <joint type="free"/>
      <geom type="capsule" size="0.035 0.10" material="pin_white" mass="0.45"/>
      <geom type="capsule" size="0.0355 0.012" pos="0 0 0.075" material="pin_red" mass="0.001"/>
    </body>
    <body name="pin6" pos="2.6 0.22 0.21">
      <joint type="free"/>
      <geom type="capsule" size="0.035 0.10" material="pin_white" mass="0.45"/>
      <geom type="capsule" size="0.0355 0.012" pos="0 0 0.075" material="pin_red" mass="0.001"/>
    </body>
    <!-- Row 4 -->
    <body name="pin7" pos="2.8 -0.33 0.21">
      <joint type="free"/>
      <geom type="capsule" size="0.035 0.10" material="pin_white" mass="0.45"/>
      <geom type="capsule" size="0.0355 0.012" pos="0 0 0.075" material="pin_red" mass="0.001"/>
    </body>
    <body name="pin8" pos="2.8 -0.11 0.21">
      <joint type="free"/>
      <geom type="capsule" size="0.035 0.10" material="pin_white" mass="0.45"/>
      <geom type="capsule" size="0.0355 0.012" pos="0 0 0.075" material="pin_red" mass="0.001"/>
    </body>
    <body name="pin9" pos="2.8 0.11 0.21">
      <joint type="free"/>
      <geom type="capsule" size="0.035 0.10" material="pin_white" mass="0.45"/>
      <geom type="capsule" size="0.0355 0.012" pos="0 0 0.075" material="pin_red" mass="0.001"/>
    </body>
    <body name="pin10" pos="2.8 0.33 0.21">
      <joint type="free"/>
      <geom type="capsule" size="0.035 0.10" material="pin_white" mass="0.45"/>
      <geom type="capsule" size="0.0355 0.012" pos="0 0 0.075" material="pin_red" mass="0.001"/>
    </body>

    <!-- Camera: tight on the pin area, elevated 3/4 view from front-left.
         Looking toward target ~(2.5, 0, 0.15) from (1.2, -1.5, 1.0). -->
    <camera name="cam" pos="1.2 -1.5 1.0" fovy="38"
            xyaxes="0.76 -0.65 0   0.27 0.32 0.91"/>
  </worldbody>
</mujoco>
