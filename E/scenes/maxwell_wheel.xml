<mujoco model="maxwell_wheel">
  <!-- Maxwell wheel (yo-yo style): a heavy disc with a thin axle, suspended
       from a crossbar by two strings wound around the axle.  As the wheel
       descends, it must rotate to "unspool" the strings; rolling-without-slip
       on the strings is enforced by a joint equality between the slide and
       the hinge, q_slide = r_axle * q_hinge (polycoef "0 r 0 0 0").

       Demonstrates rotational + translational KE: a = g / (1 + I/(M*r_axle²)).
       With M=0.5, R=0.08, r_axle=0.008, I=½MR²=0.0016 →
       a = 9.81 / (1 + 0.0016/(0.5*6.4e-5)) = 9.81 / 51 ≈ 0.192 m/s². -->
  <compiler angle="radian" coordinate="local" autolimits="true"/>
  <option timestep="0.001" gravity="0 0 -9.81" integrator="implicitfast"/>

  <visual>
    <headlight diffuse="0 0 0" ambient="0.50 0.48 0.55" specular="0 0 0"/>
    <rgba haze="0.94 0.91 0.90 1"/>
    <global azimuth="120" elevation="-15" offwidth="1920" offheight="1080" fovy="38"/>
    <quality shadowsize="8192" offsamples="8"/>
    <map shadowclip="6" shadowscale="0.7"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="flat"
             rgb1="0.74 0.68 0.86" rgb2="0.74 0.68 0.86"
             width="512" height="512" mark="none" markrgb="0 0 0"/>

    <material name="floor_mat" rgba="0.94 0.91 0.90 1" specular="0" shininess="0"/>
    <material name="wood"      rgba="0.93 0.82 0.58 1" specular="0.1" shininess="0.1"/>
    <material name="wood_dark" rgba="0.78 0.65 0.40 1" specular="0.1" shininess="0.1"/>
    <material name="brass"     rgba="0.90 0.74 0.36 1" specular="0.7" shininess="0.85"/>
    <material name="axle_mat"  rgba="0.30 0.28 0.30 1" specular="0.5" shininess="0.6"/>
    <material name="string_mat" rgba="0.30 0.27 0.24 1" specular="0" shininess="0"/>
  </asset>

  <worldbody>
    <light pos="0 0 12" dir="-0.30 0.55 -1" directional="true" castshadow="true"
           diffuse="0.85 0.82 0.78" specular="0.15 0.15 0.15"/>
    <light pos="0 0 8" dir="0.40 -0.30 -1" directional="true" castshadow="false"
           diffuse="0.28 0.28 0.34" specular="0 0 0"/>

    <geom name="floor" type="plane" size="40 40 0.1" material="floor_mat"/>

    <!-- Stand: two posts + crossbar at z=1.05 -->
    <geom type="cylinder" fromto="-0.25 0 0  -0.25 0 1.05" size="0.018" material="wood_dark"/>
    <geom type="cylinder" fromto=" 0.25 0 0   0.25 0 1.05" size="0.018" material="wood_dark"/>
    <geom type="box"      pos="0 0 1.05" size="0.30 0.025 0.020" material="wood_dark"/>

    <!-- Crossbar attachment sites for the two strings -->
    <site name="cross_L" pos="0 -0.04 1.030" size="0.003"/>
    <site name="cross_R" pos="0  0.04 1.030" size="0.003"/>

    <!-- Maxwell wheel: slide + hinge with equality constraint.
         Disc axis = y (axle along y), so the heavy ring lies in the xz plane.
         Initial position is z=0.95, just below the crossbar with ~8cm of
         string already "unwound". -->
    <body name="wheel" pos="0 0 0.95">
      <joint name="slider" type="slide" axis="0 0 1"
             damping="0.001" range="-0.75 0.05"/>
      <joint name="axle"   type="hinge" axis="0 1 0"
             damping="0.0005"/>

      <!-- Heavy disc (the wheel itself) -->
      <geom name="disc" type="cylinder"
            fromto="0 -0.006 0  0 0.006 0" size="0.080"
            material="brass" mass="0.50"/>

      <!-- Thin axle sticking out either side (massless: inertia is in the disc) -->
      <geom name="axle_L" type="cylinder"
            fromto="0 -0.046 0  0 -0.006 0" size="0.008"
            material="axle_mat" mass="0"/>
      <geom name="axle_R" type="cylinder"
            fromto="0  0.006 0  0  0.046 0" size="0.008"
            material="axle_mat" mass="0"/>

      <!-- Sites where the strings attach to the axle ends -->
      <site name="axle_L_site" pos="0 -0.040 0" size="0.003"/>
      <site name="axle_R_site" pos="0  0.040 0" size="0.003"/>
    </body>

    <!-- 3/4 view from front-right, framing the full descent (z 0.20 to 1.00) -->
    <camera name="cam" pos="1.20 -0.85 0.65" fovy="38"
            xyaxes="0.578 0.816 0   -0.024 0.017 1.000"/>
  </worldbody>

  <!-- Visual strings: two thin spatial tendons from crossbar down to axle ends.
       These are decoration only; the physics is enforced by the equality. -->
  <tendon>
    <spatial name="string_L" width="0.0012" rgba="0.20 0.18 0.15 1" limited="false">
      <site site="cross_L"/>
      <site site="axle_L_site"/>
    </spatial>
    <spatial name="string_R" width="0.0012" rgba="0.20 0.18 0.15 1" limited="false">
      <site site="cross_R"/>
      <site site="axle_R_site"/>
    </spatial>
  </tendon>

  <!-- Rolling-without-slip constraint between the slider and the hinge:
       q_slider = r_axle * q_hinge.  polycoef "0 0.008 0 0 0" means
       f(q_axle) = 0.008 * q_axle, so the equality enforces
       q_slider - 0.008 * q_axle = 0 (descending wheel must rotate). -->
  <equality>
    <joint joint1="slider" joint2="axle" polycoef="0 0.008 0 0 0"/>
  </equality>
</mujoco>
