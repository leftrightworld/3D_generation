<mujoco model="projectile_jenga">
  <compiler angle="radian" coordinate="local" autolimits="true"/>
  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast"
          impratio="3" cone="elliptic"/>

  <visual>
    <headlight diffuse="0 0 0" ambient="0.50 0.48 0.55" specular="0 0 0"/>
    <rgba haze="0.94 0.91 0.90 1"/>
    <global azimuth="120" elevation="-15" offwidth="1920" offheight="1080" fovy="38"/>
    <quality shadowsize="8192" offsamples="8"/>
    <map shadowclip="6" shadowscale="0.7"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="flat"
             rgb1="0.74 0.68 0.86" rgb2="0.74 0.68 0.86"
             width="512" height="512"
             mark="none" markrgb="0 0 0"/>

    <material name="floor_mat" rgba="0.94 0.91 0.90 1"
              specular="0.0" shininess="0.0"/>
    <material name="block_cream" rgba="0.96 0.92 0.85 1"
              specular="0.1" shininess="0.1"/>
    <material name="block_cream_dark" rgba="0.90 0.84 0.74 1"
              specular="0.1" shininess="0.1"/>
    <material name="projectile_dark" rgba="0.32 0.38 0.42 1"
              specular="0.3" shininess="0.4"/>
  </asset>

  <default>
    <geom friction="0.7 0.04 0.001" solref="0.005 1" solimp="0.95 0.99 0.001"/>
  </default>

  <worldbody>
    <light pos="0 0 12" dir="-0.30 0.55 -1" directional="true" castshadow="true"
           diffuse="0.85 0.82 0.78" specular="0.15 0.15 0.15"/>
    <light pos="0 0 8" dir="0.40 -0.30 -1" directional="true" castshadow="false"
           diffuse="0.28 0.28 0.34" specular="0 0 0"/>

    <geom name="floor" type="plane" size="40 40 0.1" material="floor_mat"/>

    <!-- Projectile: small dense sphere ("cannonball"), launched from the left.
         Heavier than the entire tower so it'll definitely topple it. -->
    <body name="projectile" pos="-1.6 0 0.30">
      <joint name="proj_free" type="free"/>
      <geom name="proj_geom" type="sphere" size="0.045"
            mass="2.0" material="projectile_dark"/>
    </body>

    <!-- Jenga-like tower at +x. 2 wide x 2 deep x 6 layers = 24 blocks.
         Each block: 0.07 x 0.07 x 0.05 (LxWxH).
         Alternate block color slightly per layer for visual interest. -->
    <!-- Layer 0 -->
    <body pos="1.6 -0.038 0.026"><joint type="free"/><geom type="box" size="0.035 0.035 0.025" mass="0.06" material="block_cream"/></body>
    <body pos="1.6  0.038 0.026"><joint type="free"/><geom type="box" size="0.035 0.035 0.025" mass="0.06" material="block_cream"/></body>
    <body pos="1.676 -0.038 0.026"><joint type="free"/><geom type="box" size="0.035 0.035 0.025" mass="0.06" material="block_cream"/></body>
    <body pos="1.676  0.038 0.026"><joint type="free"/><geom type="box" size="0.035 0.035 0.025" mass="0.06" material="block_cream"/></body>
    <!-- Layer 1 -->
    <body pos="1.6 -0.038 0.078"><joint type="free"/><geom type="box" size="0.035 0.035 0.025" mass="0.06" material="block_cream_dark"/></body>
    <body pos="1.6  0.038 0.078"><joint type="free"/><geom type="box" size="0.035 0.035 0.025" mass="0.06" material="block_cream_dark"/></body>
    <body pos="1.676 -0.038 0.078"><joint type="free"/><geom type="box" size="0.035 0.035 0.025" mass="0.06" material="block_cream_dark"/></body>
    <body pos="1.676  0.038 0.078"><joint type="free"/><geom type="box" size="0.035 0.035 0.025" mass="0.06" material="block_cream_dark"/></body>
    <!-- Layer 2 -->
    <body pos="1.6 -0.038 0.130"><joint type="free"/><geom type="box" size="0.035 0.035 0.025" mass="0.06" material="block_cream"/></body>
    <body pos="1.6  0.038 0.130"><joint type="free"/><geom type="box" size="0.035 0.035 0.025" mass="0.06" material="block_cream"/></body>
    <body pos="1.676 -0.038 0.130"><joint type="free"/><geom type="box" size="0.035 0.035 0.025" mass="0.06" material="block_cream"/></body>
    <body pos="1.676  0.038 0.130"><joint type="free"/><geom type="box" size="0.035 0.035 0.025" mass="0.06" material="block_cream"/></body>
    <!-- Layer 3 -->
    <body pos="1.6 -0.038 0.182"><joint type="free"/><geom type="box" size="0.035 0.035 0.025" mass="0.06" material="block_cream_dark"/></body>
    <body pos="1.6  0.038 0.182"><joint type="free"/><geom type="box" size="0.035 0.035 0.025" mass="0.06" material="block_cream_dark"/></body>
    <body pos="1.676 -0.038 0.182"><joint type="free"/><geom type="box" size="0.035 0.035 0.025" mass="0.06" material="block_cream_dark"/></body>
    <body pos="1.676  0.038 0.182"><joint type="free"/><geom type="box" size="0.035 0.035 0.025" mass="0.06" material="block_cream_dark"/></body>
    <!-- Layer 4 -->
    <body pos="1.6 -0.038 0.234"><joint type="free"/><geom type="box" size="0.035 0.035 0.025" mass="0.06" material="block_cream"/></body>
    <body pos="1.6  0.038 0.234"><joint type="free"/><geom type="box" size="0.035 0.035 0.025" mass="0.06" material="block_cream"/></body>
    <body pos="1.676 -0.038 0.234"><joint type="free"/><geom type="box" size="0.035 0.035 0.025" mass="0.06" material="block_cream"/></body>
    <body pos="1.676  0.038 0.234"><joint type="free"/><geom type="box" size="0.035 0.035 0.025" mass="0.06" material="block_cream"/></body>
    <!-- Layer 5 (top) -->
    <body pos="1.6 -0.038 0.286"><joint type="free"/><geom type="box" size="0.035 0.035 0.025" mass="0.06" material="block_cream_dark"/></body>
    <body pos="1.6  0.038 0.286"><joint type="free"/><geom type="box" size="0.035 0.035 0.025" mass="0.06" material="block_cream_dark"/></body>
    <body pos="1.676 -0.038 0.286"><joint type="free"/><geom type="box" size="0.035 0.035 0.025" mass="0.06" material="block_cream_dark"/></body>
    <body pos="1.676  0.038 0.286"><joint type="free"/><geom type="box" size="0.035 0.035 0.025" mass="0.06" material="block_cream_dark"/></body>

    <!-- Camera: distance ~2.55m so 3.3m wide scene fits the 16:9 frame.
         Position from (-0.5, -2.3, 0.7) looking toward (0.5, 0, 0.25). -->
    <camera name="cam" pos="-0.5 -2.3 0.7" fovy="40"
            xyaxes="0.917 -0.398 0   0.070 0.161 0.984"/>
  </worldbody>
</mujoco>
