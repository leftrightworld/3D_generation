<mujoco model="spring_mass">
  <!-- Vertical mass-spring oscillator.  A point mass hangs from the ceiling
       via a slide joint with stiffness K.  Equilibrium is below the natural
       length due to gravity, then the mass undergoes SHM about that point. -->
  <compiler angle="radian" coordinate="local" autolimits="true"/>
  <option timestep="0.001" gravity="0 0 -9.81" integrator="implicitfast"/>

  <visual>
    <headlight diffuse="0 0 0" ambient="0.50 0.48 0.55" specular="0 0 0"/>
    <rgba haze="0.94 0.91 0.90 1"/>
    <global azimuth="120" elevation="-15" offwidth="1920" offheight="1080" fovy="38"/>
    <quality shadowsize="8192" offsamples="8"/>
    <map shadowclip="6" shadowscale="0.7"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="flat"
             rgb1="0.74 0.68 0.86" rgb2="0.74 0.68 0.86"
             width="512" height="512" mark="none" markrgb="0 0 0"/>

    <material name="floor_mat" rgba="0.94 0.91 0.90 1" specular="0" shininess="0"/>
    <material name="wood" rgba="0.93 0.82 0.58 1" specular="0.1" shininess="0.1"/>
    <material name="wood_dark" rgba="0.78 0.65 0.40 1" specular="0.1" shininess="0.1"/>
    <material name="mass_red" rgba="0.86 0.34 0.30 1" specular="0.35" shininess="0.4"/>
    <material name="spring_mat" rgba="0.55 0.50 0.48 1" specular="0.6" shininess="0.6"/>
  </asset>

  <worldbody>
    <light pos="0 0 12" dir="-0.30 0.55 -1" directional="true" castshadow="true"
           diffuse="0.85 0.82 0.78" specular="0.15 0.15 0.15"/>
    <light pos="0 0 8" dir="0.40 -0.30 -1" directional="true" castshadow="false"
           diffuse="0.28 0.28 0.34" specular="0 0 0"/>

    <geom name="floor" type="plane" size="40 40 0.1" material="floor_mat"/>

    <!-- Wooden stand: 2 vertical posts + a top crossbeam -->
    <geom type="box" size="0.04 0.04 0.85" pos="-0.32 0.18 0.85" material="wood"/>
    <geom type="box" size="0.04 0.04 0.85" pos=" 0.32 0.18 0.85" material="wood"/>
    <geom type="box" size="0.40 0.04 0.04" pos="0 0.18 1.74" material="wood_dark"/>

    <!-- Anchor "block" at the bottom of the crossbeam; the spring attaches here -->
    <site name="anchor" pos="0 0.18 1.69" size="0.012"/>

    <!-- The hanging mass.  Slide joint along z; positive z is up.
         At qpos=0 the mass center is at body origin (0, 0.18, 1.00).
         Gravity will pull it down; spring restores. -->
    <body name="mass" pos="0 0.18 1.00">
      <joint name="spring_slide" type="slide" axis="0 0 1"
             stiffness="30" damping="0.25" range="-0.6 0.6"
             springref="0"/>
      <site name="hook" pos="0 0 0.08" size="0.010"/>
      <geom type="box" size="0.08 0.08 0.08" mass="0.4"
            material="mass_red"/>
    </body>

    <!-- Camera: front-facing, looking slightly up to capture the full
         spring + mass + crossbeam stack. -->
    <camera name="cam" pos="0.5 -2.0 1.05" fovy="38"
            xyaxes="0.97 0.24 0   -0.060 0.245 0.968"/>
  </worldbody>

  <!-- Spring rendered as a spatial tendon between anchor (world) and hook (mass). -->
  <tendon>
    <spatial name="spring_vis" width="0.012" rgba="0.55 0.50 0.48 1"
             limited="false">
      <site site="anchor"/>
      <site site="hook"/>
    </spatial>
  </tendon>
</mujoco>
