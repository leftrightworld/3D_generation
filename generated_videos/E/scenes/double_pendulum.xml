<mujoco model="double_pendulum">
  <compiler angle="radian" coordinate="local" autolimits="true"/>
  <option timestep="0.001" gravity="0 0 -9.81" integrator="implicitfast"/>

  <visual>
    <headlight diffuse="0 0 0" ambient="0.50 0.48 0.55" specular="0 0 0"/>
    <rgba haze="0.94 0.91 0.90 1"/>
    <global azimuth="120" elevation="-15" offwidth="1920" offheight="1080" fovy="40"/>
    <quality shadowsize="8192" offsamples="8"/>
    <map shadowclip="6" shadowscale="0.7"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="flat"
             rgb1="0.74 0.68 0.86" rgb2="0.74 0.68 0.86"
             width="512" height="512" mark="none" markrgb="0 0 0"/>

    <material name="floor_mat" rgba="0.94 0.91 0.90 1" specular="0" shininess="0"/>
    <material name="wood" rgba="0.93 0.82 0.58 1" specular="0.1" shininess="0.1"/>
    <material name="rod_mat" rgba="0.30 0.27 0.24 1" specular="0.3" shininess="0.4"/>
    <material name="bob_red" rgba="0.86 0.34 0.30 1" specular="0.4" shininess="0.45"/>
    <material name="bob_blue" rgba="0.30 0.50 0.78 1" specular="0.4" shininess="0.45"/>
  </asset>

  <worldbody>
    <light pos="0 0 12" dir="-0.35 0.55 -1" directional="true" castshadow="true"
           diffuse="0.85 0.82 0.78" specular="0.15 0.15 0.15"/>
    <light pos="0 0 8" dir="0.45 -0.30 -1" directional="true" castshadow="false"
           diffuse="0.30 0.30 0.36" specular="0 0 0"/>

    <geom name="floor" type="plane" size="40 40 0.1" material="floor_mat"/>

    <!-- L-shaped stand: vertical post + horizontal arm toward camera -->
    <geom type="box" size="0.045 0.045 0.95" pos="0 0.55 0.95" material="wood"/>
    <geom type="box" size="0.045 0.65 0.045" pos="0 -0.10 1.85" material="wood"/>

    <!-- Hinge anchor at the tip of the horizontal arm: (0, -0.75, 1.805) -->
    <body name="arm1" pos="0 -0.75 1.805">
      <joint name="h1" type="hinge" axis="0 1 0" damping="0.001"/>
      <geom name="rod1" type="capsule" fromto="0 0 0   0 0 -0.42"
            size="0.012" material="rod_mat" contype="0" conaffinity="0"/>
      <geom name="bob1" type="sphere" pos="0 0 -0.42" size="0.060"
            mass="0.18" material="bob_red" contype="0" conaffinity="0"/>

      <!-- Second arm hinged at the end of arm1 -->
      <body name="arm2" pos="0 0 -0.42">
        <joint name="h2" type="hinge" axis="0 1 0" damping="0.001"/>
        <geom name="rod2" type="capsule" fromto="0 0 0   0 0 -0.40"
              size="0.011" material="rod_mat" contype="0" conaffinity="0"/>
        <geom name="bob2" type="sphere" pos="0 0 -0.40" size="0.055"
              mass="0.15" material="bob_blue" contype="0" conaffinity="0"/>
      </body>
    </body>

    <!-- Camera: 3/4 view aimed near pendulum mid-height so bobs sit in the
         middle of the frame instead of the top.  Looks at (0, 0, 1.3). -->
    <camera name="cam" pos="2.4 -2.6 1.55" fovy="40"
            xyaxes="0.735 0.678 0   -0.038 0.041 0.998"/>
  </worldbody>
</mujoco>
