<mujoco model="loop_the_loop">
  <compiler angle="radian" coordinate="local" autolimits="true"/>
  <option timestep="0.0005" gravity="0 0 -9.81" integrator="implicitfast"
          impratio="5" cone="elliptic"/>

  <visual>
    <headlight diffuse="0 0 0" ambient="0.50 0.48 0.55" specular="0 0 0"/>
    <rgba haze="0.94 0.91 0.90 1"/>
    <global azimuth="120" elevation="-15" offwidth="1920" offheight="1080" fovy="36"/>
    <quality shadowsize="8192" offsamples="8"/>
    <map shadowclip="6" shadowscale="0.7"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="flat"
             rgb1="0.74 0.68 0.86" rgb2="0.74 0.68 0.86"
             width="512" height="512" mark="none" markrgb="0 0 0"/>
    <material name="floor_mat" rgba="0.94 0.91 0.90 1" specular="0" shininess="0"/>
    <material name="track_warm" rgba="0.93 0.82 0.58 1" specular="0.15" shininess="0.2"/>
    <material name="wall_glass" rgba="0.85 0.82 0.78 0.18" specular="0.4" shininess="0.5"/>
    <material name="ball_blue"  rgba="0.30 0.50 0.78 1" specular="0.55" shininess="0.65"/>
  </asset>

  <default>
    <!-- Very low friction so the ball can keep orbiting; ball-on-track is
         primarily a normal-force interaction here, not a frictional one. -->
    <geom friction="0.06 0.003 0.0001" solref="0.002 1" solimp="0.97 0.99 0.001"/>
  </default>

  <worldbody>
    <light pos="0 0 12" dir="-0.30 0.55 -1" directional="true" castshadow="true"
           diffuse="0.85 0.82 0.78" specular="0.15 0.15 0.15"/>
    <light pos="0 0 8" dir="0.40 -0.30 -1" directional="true" castshadow="false"
           diffuse="0.28 0.28 0.34" specular="0 0 0"/>

    <geom name="floor" type="plane" size="40 40 0.1" material="floor_mat"/>

    <!-- Loop: 28 segments, closed.  Bottom of inside-surface at z=0. -->
    <geom type="box" pos="0.0000 0 -0.0040" euler="0 -0.00000 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="0.0676 0 0.0036" euler="0 -0.22440 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="0.1319 0 0.0261" euler="0 -0.44880 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="0.1895 0 0.0623" euler="0 -0.67320 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="0.2377 0 0.1105" euler="0 -0.89760 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="0.2739 0 0.1681" euler="0 -1.12200 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="0.2964 0 0.2324" euler="0 -1.34640 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="0.3040 0 0.3000" euler="0 -1.57080 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="0.2964 0 0.3676" euler="0 -1.79520 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="0.2739 0 0.4319" euler="0 -2.01960 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="0.2377 0 0.4895" euler="0 -2.24399 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="0.1895 0 0.5377" euler="0 -2.46839 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="0.1319 0 0.5739" euler="0 -2.69279 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="0.0676 0 0.5964" euler="0 -2.91719 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="0.0000 0 0.6040" euler="0 -3.14159 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="-0.0676 0 0.5964" euler="0 -3.36599 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="-0.1319 0 0.5739" euler="0 -3.59039 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="-0.1895 0 0.5377" euler="0 -3.81479 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="-0.2377 0 0.4895" euler="0 -4.03919 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="-0.2739 0 0.4319" euler="0 -4.26359 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="-0.2964 0 0.3676" euler="0 -4.48799 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="-0.3040 0 0.3000" euler="0 -4.71239 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="-0.2964 0 0.2324" euler="0 -4.93679 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="-0.2739 0 0.1681" euler="0 -5.16119 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="-0.2377 0 0.1105" euler="0 -5.38559 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="-0.1895 0 0.0623" euler="0 -5.60999 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="-0.1319 0 0.0261" euler="0 -5.83439 0" size="0.0363 0.06 0.004" material="track_warm"/>
    <geom type="box" pos="-0.0676 0 0.0036" euler="0 -6.05879 0" size="0.0363 0.06 0.004" material="track_warm"/>

    <geom type="box" pos="0 -0.0640 0.3000" size="0.35 0.003 0.35" material="wall_glass" contype="0" conaffinity="0"/>
    <geom type="box" pos="0 0.0640 0.3000" size="0.35 0.003 0.35" material="wall_glass" contype="0" conaffinity="0"/>

    <!-- Ball: starts on the loop bottom, gets a horizontal launch via CLI
         init-qvel.  Center z = BALL_R so it sits just inside the loop. -->
    <body name="ball" pos="0 0 0.0410">
      <joint name="ball_free" type="free"/>
      <geom name="ball_geom" type="sphere" size="0.04" mass="0.04"
            material="ball_blue"/>
    </body>

    <!-- Camera: nearly pure side view (-y), slight tilt so the loop reads as
         a true circle. -->
    <camera name="cam" pos="0.40 -2.50 0.35" fovy="36"
            xyaxes="0.987 0.158 0   -0.003 0.019 1.000"/>
  </worldbody>
</mujoco>
