<mujoco model="incline_friction">
  <!-- Two blocks of identical mass start side-by-side at the top of a 25-degree
       ramp.  Block A (warm) has high friction (mu = 0.6 > tan 25), so it does
       not move.  Block B (blue) has low friction (mu = 0.05), so it slides
       down.  Demonstrates the static-friction threshold mu_s >= tan theta. -->
  <compiler angle="radian" coordinate="local" autolimits="true"/>
  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast"
          impratio="3" cone="elliptic"/>

  <visual>
    <headlight diffuse="0 0 0" ambient="0.50 0.48 0.55" specular="0 0 0"/>
    <rgba haze="0.94 0.91 0.90 1"/>
    <global azimuth="120" elevation="-15" offwidth="1920" offheight="1080" fovy="38"/>
    <quality shadowsize="8192" offsamples="8"/>
    <map shadowclip="6" shadowscale="0.7"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="flat"
             rgb1="0.74 0.68 0.86" rgb2="0.74 0.68 0.86"
             width="512" height="512" mark="none" markrgb="0 0 0"/>

    <material name="floor_mat" rgba="0.94 0.91 0.90 1" specular="0" shininess="0"/>
    <material name="ramp_mat" rgba="0.86 0.71 0.42 1" specular="0.1" shininess="0.15"/>
    <material name="ramp_dark" rgba="0.70 0.55 0.30 1" specular="0.1" shininess="0.15"/>
    <material name="block_cream" rgba="0.96 0.85 0.66 1" specular="0.2" shininess="0.25"/>
    <material name="block_blue" rgba="0.34 0.52 0.80 1" specular="0.35" shininess="0.4"/>
  </asset>

  <worldbody>
    <light pos="0 0 12" dir="-0.30 0.55 -1" directional="true" castshadow="true"
           diffuse="0.85 0.82 0.78" specular="0.15 0.15 0.15"/>
    <light pos="0 0 8" dir="0.40 -0.30 -1" directional="true" castshadow="false"
           diffuse="0.28 0.28 0.34" specular="0 0 0"/>

    <geom name="floor" type="plane" size="40 40 0.1" material="floor_mat"/>

    <!-- Ramp: tilted box at -25deg about y (so +x end goes up).
         Half-size (1.5, 0.55, 0.04); center at (0, 0, 0.65).
         High end at world x ≈ +1.36, z ≈ 1.30.
         Low end at world x ≈ -1.36, z ≈ 0.10. -->
    <!-- Ramp friction set very low so each block's own mu dominates the
         contact (MuJoCo combines paired frictions by element-wise max). -->
    <geom name="ramp" type="box" size="1.5 0.55 0.04"
          pos="0 0 0.65" euler="0 -0.4363 0"
          material="ramp_mat" friction="0.001 0.0001 0.00001"/>
    <!-- A thin side rail on the front edge so the slope is visually clear -->
    <geom type="box" size="1.5 0.012 0.018"
          pos="0 -0.55 0.69" euler="0 -0.4363 0" material="ramp_dark"/>

    <!-- Two blocks released from the top of the ramp.
         Top surface point at box-x = +1.30, box-y = ±0.20, on top face.
         World pos = R_y(-25deg) * (1.30, ±0.20, 0.10) + (0, 0, 0.65).
         R_y(-25)*(1.30, 0, 0.10) = (1.30*cos25 + 0.10*sin25, 0, -1.30*(-sin25) + 0.10*cos25)
                                  = (1.178 + 0.0423, 0, 0.549 + 0.0906)
                                  ≈ (1.221, 0, 0.639)
         World: (1.221, ±0.20, 1.289). -->

    <!-- Block A: high friction (cream).  Will NOT slide (mu > tan 25 = 0.466). -->
    <body name="blockA" pos="1.221 -0.20 1.289" euler="0 -0.4363 0">
      <joint type="free"/>
      <geom type="box" size="0.06 0.06 0.05" mass="0.3"
            material="block_cream" friction="0.6 0.04 0.001"/>
    </body>

    <!-- Block B: low friction (blue).  Will slide down. -->
    <body name="blockB" pos="1.221 0.20 1.289" euler="0 -0.4363 0">
      <joint type="free"/>
      <geom type="box" size="0.06 0.06 0.05" mass="0.3"
            material="block_blue" friction="0.05 0.001 0.0001"/>
    </body>

    <!-- Camera: in front of and slightly above the ramp -->
    <camera name="cam" pos="0.3 -3.0 1.4" fovy="38"
            xyaxes="0.995 0.100 0   -0.030 0.295 0.955"/>
  </worldbody>
</mujoco>
