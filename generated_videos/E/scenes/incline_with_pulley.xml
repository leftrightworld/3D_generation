<mujoco model="incline_with_pulley">
  <!-- Block on a 30° ramp connected over a pulley to a hanging mass.
       Joint equality (Atwood-style, polycoef "0 -1 0 0 0") enforces
       q_ramp + q_hang = 0: hanger descends => block climbs the ramp.
       Both slide joints use q=0 at the start pose (block mid-ramp,
       hanger high on a long vertical string). -->
  <compiler angle="radian" coordinate="local" autolimits="true"/>
  <option timestep="0.001" gravity="0 0 -9.81" integrator="implicitfast"
          impratio="3" cone="elliptic"/>

  <visual>
    <headlight diffuse="0 0 0" ambient="0.50 0.48 0.55" specular="0 0 0"/>
    <rgba haze="0.94 0.91 0.90 1"/>
    <global azimuth="120" elevation="-15" offwidth="1920" offheight="1080" fovy="38"/>
    <quality shadowsize="8192" offsamples="8"/>
    <map shadowclip="6" shadowscale="0.7"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="flat"
             rgb1="0.74 0.68 0.86" rgb2="0.74 0.68 0.86"
             width="512" height="512" mark="none" markrgb="0 0 0"/>

    <material name="floor_mat" rgba="0.94 0.91 0.90 1" specular="0" shininess="0"/>
    <material name="ramp_mat" rgba="0.86 0.71 0.42 1" specular="0.1" shininess="0.15"/>
    <material name="ramp_dark" rgba="0.70 0.55 0.30 1" specular="0.1" shininess="0.15"/>
    <material name="block_blue" rgba="0.34 0.52 0.80 1" specular="0.35" shininess="0.4"/>
    <material name="pulley_mat" rgba="0.30 0.28 0.30 1" specular="0.5" shininess="0.6"/>
    <material name="m_heavy" rgba="0.86 0.34 0.30 1" specular="0.3" shininess="0.4"/>
    <material name="string_mat" rgba="0.30 0.27 0.24 1" specular="0" shininess="0"/>
  </asset>

  <worldbody>
    <light pos="0 0 12" dir="-0.30 0.55 -1" directional="true" castshadow="true"
           diffuse="0.85 0.82 0.78" specular="0.15 0.15 0.15"/>
    <light pos="0 0 8" dir="0.40 -0.30 -1" directional="true" castshadow="false"
           diffuse="0.28 0.28 0.34" specular="0 0 0"/>

    <geom name="floor" type="plane" size="40 40 0.1" material="floor_mat"/>

    <!-- 30° ramp: low end left, high end right (+x). -->
    <geom name="ramp" type="box" size="1.5 0.55 0.04"
          pos="0 0 0.65" euler="0 -0.5235987756 0"
          material="ramp_mat" contype="0" conaffinity="0"/>
    <geom type="box" size="1.5 0.012 0.018"
          pos="0 -0.55 0.69" euler="0 -0.5235987756 0" material="ramp_dark"
          contype="0" conaffinity="0"/>

    <!-- Pulley at the high (+x) end of the ramp -->
    <geom type="cylinder" size="0.09 0.022" pos="1.30 0 1.50"
          euler="1.5708 0 0" material="pulley_mat"
          contype="0" conaffinity="0"/>
    <geom type="cylinder" size="0.022 0.028" pos="1.30 0 1.50"
          euler="1.5708 0 0" material="pulley_mat"
          contype="0" conaffinity="0"/>

    <site name="pulley_ramp" pos="1.22 0 1.54" size="0.008"/>
    <site name="pulley_drop" pos="1.40 0 1.54" size="0.008"/>

    <!-- Teaching arrows (visual only) -->
    <geom name="arrow_weight_comp" type="capsule"
          fromto="0.55 0 1.02 0.42 0 0.945"
          size="0.010" rgba="0.88 0.28 0.24 0.75" contype="0" conaffinity="0"/>

    <!-- Block on the ramp: q=0 is mid-ramp; +q moves up-ramp toward the pulley. -->
    <body name="block" pos="0.674 0 1.097" euler="0 -0.5235987756 0">
      <joint name="j_ramp" type="slide" axis="1 0 0"
             damping="13.0" range="0 0.52"/>
      <site name="hook_block" pos="0.06 0 0.05" size="0.008"/>
      <geom type="box" size="0.07 0.07 0.06" mass="0.35"
            material="block_blue" friction="0.04 0.001 0.0001"
            contype="0" conaffinity="0"/>
    </body>

    <!-- Hanging mass: q=0 is high on a long vertical string; negative q descends. -->
    <body name="m_hang" pos="1.40 0 1.02">
      <joint name="j_hang" type="slide" axis="0 0 1"
             damping="13.0" range="-0.68 0"/>
      <site name="hook_hang" pos="0 0 0.08" size="0.008"/>
      <geom type="box" size="0.08 0.08 0.08" mass="0.55" material="m_heavy"
            contype="0" conaffinity="0"/>
    </body>

    <!-- Side-view camera: looks along +y, screen up = +z -->
    <camera name="cam" pos="0.45 -4.2 0.95" fovy="34"
            xyaxes="1 0 0  0 0 1"/>
  </worldbody>

  <tendon>
    <spatial name="string_ramp" width="0.004" rgba="0.30 0.27 0.24 1" limited="false">
      <site site="hook_block"/>
      <site site="pulley_ramp"/>
    </spatial>
    <spatial name="string_drop" width="0.004" rgba="0.30 0.27 0.24 1" limited="false">
      <site site="pulley_drop"/>
      <site site="hook_hang"/>
    </spatial>
  </tendon>

  <!-- Inextensible string: q_ramp + q_hang = 0 — hanger down pulls block up-ramp. -->
  <equality>
    <joint joint1="j_ramp" joint2="j_hang" polycoef="0 -1 0 0 0"/>
  </equality>
</mujoco>
