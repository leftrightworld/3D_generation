<mujoco model="atwood_machine">
  <!-- Atwood machine: two masses on opposite sides of a pulley, connected by
       an inextensible string.  The string is modelled by a joint-equality
       constraint (q_left + q_right = 0), and rendered as two spatial tendons. -->
  <compiler angle="radian" coordinate="local" autolimits="true"/>
  <option timestep="0.001" gravity="0 0 -9.81" integrator="implicitfast"/>

  <visual>
    <headlight diffuse="0 0 0" ambient="0.50 0.48 0.55" specular="0 0 0"/>
    <rgba haze="0.94 0.91 0.90 1"/>
    <global azimuth="120" elevation="-15" offwidth="1920" offheight="1080" fovy="38"/>
    <quality shadowsize="8192" offsamples="8"/>
    <map shadowclip="6" shadowscale="0.7"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="flat"
             rgb1="0.74 0.68 0.86" rgb2="0.74 0.68 0.86"
             width="512" height="512" mark="none" markrgb="0 0 0"/>

    <material name="floor_mat" rgba="0.94 0.91 0.90 1" specular="0" shininess="0"/>
    <material name="wood" rgba="0.93 0.82 0.58 1" specular="0.1" shininess="0.1"/>
    <material name="wood_dark" rgba="0.78 0.65 0.40 1" specular="0.1" shininess="0.1"/>
    <material name="pulley_mat" rgba="0.30 0.28 0.30 1" specular="0.5" shininess="0.6"/>
    <material name="m_heavy" rgba="0.86 0.34 0.30 1" specular="0.3" shininess="0.4"/>
    <material name="m_light" rgba="0.30 0.50 0.78 1" specular="0.3" shininess="0.4"/>
    <material name="string_mat" rgba="0.30 0.27 0.24 1" specular="0" shininess="0"/>
  </asset>

  <worldbody>
    <light pos="0 0 12" dir="-0.30 0.55 -1" directional="true" castshadow="true"
           diffuse="0.85 0.82 0.78" specular="0.15 0.15 0.15"/>
    <light pos="0 0 8" dir="0.40 -0.30 -1" directional="true" castshadow="false"
           diffuse="0.28 0.28 0.34" specular="0 0 0"/>

    <geom name="floor" type="plane" size="40 40 0.1" material="floor_mat"/>

    <!-- Frame: 2 posts + 1 top crossbeam -->
    <geom type="box" size="0.05 0.05 0.95" pos="-0.65 0.20 0.95" material="wood"/>
    <geom type="box" size="0.05 0.05 0.95" pos=" 0.65 0.20 0.95" material="wood"/>
    <geom type="box" size="0.75 0.05 0.05" pos="0 0.20 1.95" material="wood_dark"/>

    <!-- Pulley wheel (visual): a flat cylinder at the center top. -->
    <geom type="cylinder" size="0.10 0.025" pos="0 0.18 1.90"
          euler="1.5708 0 0" material="pulley_mat"/>
    <geom type="cylinder" size="0.025 0.030" pos="0 0.15 1.90"
          euler="1.5708 0 0" material="pulley_mat"/>

    <!-- Sites where the string leaves the top of the pulley.  Both at
         z = 1.90 + 0.10 = 2.00, at x = ±0.10 (radius offset). -->
    <site name="pulley_L" pos="-0.10 0.18 2.00" size="0.008"/>
    <site name="pulley_R" pos=" 0.10 0.18 2.00" size="0.008"/>

    <!-- Heavy mass (red) on the LEFT.  Slide joint along z.
         Damping is high so motion stays visible across a ~3 s clip rather
         than slamming into the joint limits in under 1 s. -->
    <body name="m_heavy" pos="-0.10 0.18 1.10">
      <joint name="j_heavy" type="slide" axis="0 0 1"
             damping="2.5" range="-0.6 0.5"/>
      <site name="hook_L" pos="0 0 0.07" size="0.008"/>
      <geom type="box" size="0.07 0.07 0.07" mass="0.50" material="m_heavy"/>
    </body>

    <!-- Light mass (blue) on the RIGHT. -->
    <body name="m_light" pos="0.10 0.18 1.10">
      <joint name="j_light" type="slide" axis="0 0 1"
             damping="2.5" range="-0.5 0.6"/>
      <site name="hook_R" pos="0 0 0.06" size="0.008"/>
      <geom type="box" size="0.06 0.06 0.06" mass="0.32" material="m_light"/>
    </body>

    <!-- Camera: pulled back + lifted so both masses stay in frame for their
         full travel (~ z 0.4 to z 1.7). -->
    <camera name="cam" pos="0.2 -3.0 1.55" fovy="42"
            xyaxes="0.997 0.067 0   -0.005 0.083 0.997"/>
  </worldbody>

  <!-- Visual strings: two spatial tendons from each hook to the pulley top -->
  <tendon>
    <spatial name="string_L" width="0.004" rgba="0.30 0.27 0.24 1" limited="false">
      <site site="hook_L"/>
      <site site="pulley_L"/>
    </spatial>
    <spatial name="string_R" width="0.004" rgba="0.30 0.27 0.24 1" limited="false">
      <site site="hook_R"/>
      <site site="pulley_R"/>
    </spatial>
  </tendon>

  <!-- Inextensible string: the two slide joints move opposite to each other.
       polycoef "0 1 0 0 0" means f(q_heavy, q_light) = q_heavy + q_light = 0,
       i.e. mass goes down on one side <=> mass goes up by the same amount on
       the other side. -->
  <equality>
    <joint joint1="j_heavy" joint2="j_light" polycoef="0 -1 0 0 0"/>
  </equality>
</mujoco>
