<mujoco model="newton_cradle">
  <compiler angle="radian" coordinate="local" autolimits="true"/>
  <!-- Small timestep + stiff elastic contacts → momentum transfer chain. -->
  <option timestep="0.0005" gravity="0 0 -9.81" integrator="implicitfast"
          impratio="5" cone="elliptic"/>

  <visual>
    <headlight diffuse="0 0 0" ambient="0.50 0.48 0.55" specular="0 0 0"/>
    <rgba haze="0.94 0.91 0.90 1"/>
    <global azimuth="120" elevation="-15" offwidth="1920" offheight="1080" fovy="35"/>
    <quality shadowsize="8192" offsamples="8"/>
    <map shadowclip="6" shadowscale="0.7"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="flat"
             rgb1="0.74 0.68 0.86" rgb2="0.74 0.68 0.86"
             width="512" height="512" mark="none" markrgb="0 0 0"/>

    <material name="floor_mat" rgba="0.94 0.91 0.90 1"
              specular="0.0" shininess="0.0"/>
    <material name="frame_wood" rgba="0.86 0.71 0.42 1"
              specular="0.15" shininess="0.2"/>
    <material name="frame_wood_dark" rgba="0.70 0.55 0.30 1"
              specular="0.15" shininess="0.2"/>
    <material name="ball_brass" rgba="0.90 0.74 0.36 1"
              specular="0.7" shininess="0.85"/>
    <material name="string_mat" rgba="0.25 0.22 0.20 1"
              specular="0.0" shininess="0.0"/>
  </asset>

  <default>
    <!-- Stiff, near-elastic contacts so momentum transfers cleanly. -->
    <geom solref="0.001 1" solimp="0.99 0.999 0.0001"/>
  </default>

  <worldbody>
    <light pos="0 0 12" dir="-0.30 0.55 -1" directional="true" castshadow="true"
           diffuse="0.85 0.82 0.78" specular="0.15 0.15 0.15"/>
    <light pos="0 0 8" dir="0.40 -0.30 -1" directional="true" castshadow="false"
           diffuse="0.28 0.28 0.34" specular="0 0 0"/>

    <geom name="floor" type="plane" size="40 40 0.1" material="floor_mat"/>

    <!-- ===== Wooden cradle frame =====
         5 balls at x = -0.164, -0.082, 0, 0.082, 0.164 (spacing 0.082 = 2r + 2mm).
         Hinge anchors at z = 0.72.  String length 0.32 → ball center z = 0.40. -->

    <!-- 4 vertical posts at the corners of the base. -->
    <geom type="box" size="0.022 0.022 0.36"
          pos="-0.26 -0.16 0.36" material="frame_wood"/>
    <geom type="box" size="0.022 0.022 0.36"
          pos=" 0.26 -0.16 0.36" material="frame_wood"/>
    <geom type="box" size="0.022 0.022 0.36"
          pos="-0.26  0.16 0.36" material="frame_wood"/>
    <geom type="box" size="0.022 0.022 0.36"
          pos=" 0.26  0.16 0.36" material="frame_wood"/>

    <!-- Base feet (slightly wider) to ground the look. -->
    <geom type="box" size="0.30 0.025 0.012"
          pos="0 -0.16 0.012" material="frame_wood_dark"/>
    <geom type="box" size="0.30 0.025 0.012"
          pos="0  0.16 0.012" material="frame_wood_dark"/>

    <!-- Two horizontal top bars (the hinge bars).  Sit just above the hinge
         points (z=0.72) so the geometry hides the joint anchor. -->
    <geom type="box" size="0.30 0.018 0.018"
          pos="0 -0.16 0.738" material="frame_wood_dark"/>
    <geom type="box" size="0.30 0.018 0.018"
          pos="0  0.16 0.738" material="frame_wood_dark"/>

    <!-- Two cross-bracing top spans (visual only) connecting the top bars in y. -->
    <geom type="box" size="0.018 0.16 0.012"
          pos="-0.26 0 0.738" material="frame_wood_dark"/>
    <geom type="box" size="0.018 0.16 0.012"
          pos=" 0.26 0 0.738" material="frame_wood_dark"/>

    <!-- ===== 5 balls hanging from hinges =====
         Each body is anchored at (x_i, 0, 0.72) with a hinge along +y.
         The string + ball geom hang from the body origin in -z. -->

    <body name="ball1" pos="-0.164 0 0.72">
      <joint name="h1" type="hinge" axis="0 1 0" damping="0.00005"/>
      <geom type="capsule" fromto="0 -0.155 0   0 0 -0.32" size="0.0018"
            material="string_mat" contype="0" conaffinity="0"/>
      <geom type="capsule" fromto="0  0.155 0   0 0 -0.32" size="0.0018"
            material="string_mat" contype="0" conaffinity="0"/>
      <geom name="b1" type="sphere" pos="0 0 -0.32" size="0.04" mass="0.20"
            material="ball_brass"/>
    </body>

    <body name="ball2" pos="-0.082 0 0.72">
      <joint name="h2" type="hinge" axis="0 1 0" damping="0.00005"/>
      <geom type="capsule" fromto="0 -0.155 0   0 0 -0.32" size="0.0018"
            material="string_mat" contype="0" conaffinity="0"/>
      <geom type="capsule" fromto="0  0.155 0   0 0 -0.32" size="0.0018"
            material="string_mat" contype="0" conaffinity="0"/>
      <geom name="b2" type="sphere" pos="0 0 -0.32" size="0.04" mass="0.20"
            material="ball_brass"/>
    </body>

    <body name="ball3" pos="0 0 0.72">
      <joint name="h3" type="hinge" axis="0 1 0" damping="0.00005"/>
      <geom type="capsule" fromto="0 -0.155 0   0 0 -0.32" size="0.0018"
            material="string_mat" contype="0" conaffinity="0"/>
      <geom type="capsule" fromto="0  0.155 0   0 0 -0.32" size="0.0018"
            material="string_mat" contype="0" conaffinity="0"/>
      <geom name="b3" type="sphere" pos="0 0 -0.32" size="0.04" mass="0.20"
            material="ball_brass"/>
    </body>

    <body name="ball4" pos="0.082 0 0.72">
      <joint name="h4" type="hinge" axis="0 1 0" damping="0.00005"/>
      <geom type="capsule" fromto="0 -0.155 0   0 0 -0.32" size="0.0018"
            material="string_mat" contype="0" conaffinity="0"/>
      <geom type="capsule" fromto="0  0.155 0   0 0 -0.32" size="0.0018"
            material="string_mat" contype="0" conaffinity="0"/>
      <geom name="b4" type="sphere" pos="0 0 -0.32" size="0.04" mass="0.20"
            material="ball_brass"/>
    </body>

    <body name="ball5" pos="0.164 0 0.72">
      <joint name="h5" type="hinge" axis="0 1 0" damping="0.00005"/>
      <geom type="capsule" fromto="0 -0.155 0   0 0 -0.32" size="0.0018"
            material="string_mat" contype="0" conaffinity="0"/>
      <geom type="capsule" fromto="0  0.155 0   0 0 -0.32" size="0.0018"
            material="string_mat" contype="0" conaffinity="0"/>
      <geom name="b5" type="sphere" pos="0 0 -0.32" size="0.04" mass="0.20"
            material="ball_brass"/>
    </body>

    <!-- Camera: nearly side-on, slight 3/4 from +x side, framing all 5 balls
         and the frame top.  Looking at (~0, 0, 0.4). -->
    <camera name="cam" pos="0.15 -1.30 0.45" fovy="35"
            xyaxes="0.994 0.115 0   -0.004 0.038 0.999"/>
  </worldbody>
</mujoco>
